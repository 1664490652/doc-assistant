# 复制此文件为 .env 并填入你的 API Key
# cp .env.example .env

# ── 必填 ──
# DeepSeek（主模型）
DEEPSEEK_API_KEY=your-deepseek-api-key
# OpenAI（可选，作为 DEEPSEEK_API_KEY 的备选方案）
# OPENAI_API_KEY=sk-your-openai-key

# 阿里云百炼（备用模型 Fallback + RAG Embedding）
DASHSCOPE_API_KEY=your-dashscope-api-key

# ── 可选：主模型配置 ──
LLM_MODEL=deepseek-chat        # 主模型名称（默认值即此）
# LLM_API_KEY=sk-xxx             # 主模型 Key（显式覆盖 DEEPSEEK_API_KEY）
# LLM_BASE_URL=https://api.xxx   # 主模型端点（默认 DeepSeek，覆盖后可接入任意 OpenAI 兼容方）

# ── 可选：备用模型配置 ──
# MIDDLEWARE_FALLBACK_MODEL=qwen-turbo
# FALLBACK_API_KEY=sk-xxx        # 备用 Key（显式覆盖 DASHSCOPE_API_KEY）
# FALLBACK_BASE_URL=https://api.xxx  # 备用端点（设置后用 OpenAI 协议，否则默认 DashScope）

# ── 可选：Embedding 配置 ──
EMBEDDING_MODEL=text-embedding-v4   # Embedding 模型名称（默认值即此）
# EMBEDDING_API_KEY=sk-xxx       # Embedding Key（显式覆盖 DASHSCOPE_API_KEY）
# EMBEDDING_BASE_URL=https://api.xxx  # Embedding 端点（设置后用 OpenAI 协议，否则默认 DashScope）

# ── 可选：Middleware 开关（1=启用，0=禁用）──
# MIDDLEWARE_ENABLE_PII=1
# MIDDLEWARE_ENABLE_HUMAN_LOOP=1
